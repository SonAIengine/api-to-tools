{
  "name": "api-to-tools",
  "version": "0.1.0",
  "description": "Universal library that converts any API (OpenAPI, WSDL/SOAP, GraphQL, gRPC) into LLM-callable tool definitions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "api-to-tools": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "example": "tsx examples/basic.ts"
  },
  "keywords": [
    "api",
    "openapi",
    "swagger",
    "wsdl",
    "soap",
    "graphql",
    "grpc",
    "mcp",
    "llm",
    "tools",
    "function-calling"
  ],
  "author": "SonAIengine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SonAIengine/api-to-tools.git"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@asyncapi/parser": "^3.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.5.11",
    "graphql": "^16.13.2",
    "jayson": "^4.3.0",
    "protobufjs": "^8.0.1",
    "soap": "^1.6.4",
    "swagger2openapi": "^7.0.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
